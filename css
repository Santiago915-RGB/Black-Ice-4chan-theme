body {
  background: url('https://i.ibb.co/NdVdHff1/bg.png');
  background-repeat: repeat;
  overflow-x: hidden;
  background-size: 256px;
}

div.boardTitle {
  position: fixed !important;
  color: #3527fd !important;
  font-weight: normal !important;
  font-family: "OCR-B" !important;
  right: -6px !important;
  text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000 !important;
  font-size: 20px !important;
}

body, #boardNavDesktop, span.boardList, #navtopright, .intro span.name, #togglePostFormLink > a, #boardNavDesktop > span > a, #navtopright > a {
  color: black !important;
} .burichan_new .backlink a, .yotsuba_b_new .backlink a {
  color: #b4bec8 !important;
} span.quote {
  color: #01796F !important;
} div.sideArrows {
  color: #0000;
} .name {
  color: #88a6ff;
} .post {
  color: #dcdcfc !important;
} .subject {
  color: #3527fd !important;
} div.closed {
  color: #c40700 !important;
}
#boardNavDesktop, .boardTitle {
  position: absolute !important;
}.post, input, textarea, pre.prettyprint {
  border: 1px solid black !important;
}
.post, div.op, post.highlight, .post.highlight {
  background: #000000ce !important;
}
.post, .post.highlight {
  box-shadow: 0 0 25px black;
}
div.op {
  shadow: 0 0 100px #000;
  display: table;
  padding: 4px;
  border-radius: 2px;
}
.name, a {
  color: #666 !important;
  font-size: 16;
}
a.quotelink {
  color: #6867ec !important;
  text-decoration: none;
}
.reply:target {
  border: 1px solid #dcdcfc !important;
  background: black !important;
}
.post.highlight {
  border: 1px solid #6868ec !important;
}
.boardTitle{
  position: absolute !important;
  top: 0rem !important;
  right: 0px !important;
  writing-mode: vertical-rl;
}
hr {
  border-top: 1px dotted black !important;
  height: 0;
}
hr.abovePostForm, hr.aboveMidAd {
  border-top: 1px solid #0000 !important;
} hr.abovePostForm {
  margin-bottom: -2px !important;
}

/* etc */

.boardBanner {
  background: linear-gradient(#33144d, #7171ff);
  margin: -5px;
  padding: 76px;
  border-top: 2px solid black;
  border-bottom: 1px solid black !important;
}
#boardNavDesktop {
  width: 233px;
  top: 0;
}
#bannerCnt, .middlead, .adl, #blotter, hr:nth-of-type(3), hr:nth-of-type(2), hr#op {
  display: none !important;
}
#togglePostFormLink {
  width: 100%;
  top: 0px !important;
  position: absolute;
}
#search-box {
  background: #515151;
} #search-box:focus {
  border: 1px solid #6867ec !important;
}
#togglePostFormLink {
  font-family: "IBM Plex Sans Condensed";
  font-weight: 100;
}
input:nth-of-type(1) {
  position: relative;
  top: 2px;
}
#navtopright {
  left: 0px;
  position: absolute;
  margin-top: 21px;
}
.thread-stats {
  padding-right: 15px !important;
}

#threadWatcher{
  background: #00f;
  font-family: 'Monaco 9';
  font-size: 16px;
  border: none;
  padding: 0;
}
#twHeader {
  font-weight: normal;
  background: linear-gradient(#00f, black);
  border: 1px solid black;
  padding-top: 2px !important;
  outline: 1px solid #00f;
}
#watchList > li {
  border-top: none !important;
  margin: 0 !important;
  color: #00f;
}
#watchList > li > a {
  color: #00f !important;
}
#twPrune {
  content: url(https://i.ibb.co/R4g71C5q/nelsonmandela.png);
  margin-top: -3px !important;
}
#watchList{
  background: #000020;
  border: 1px solid #00f;
  background: linear-gradient(black, #00009e, black);
}
/* Borland code color palette*/
pre.prettyprint {
  background: #000080;
}
.com {
  color: #c0c0c0;
}
.kwd, .pun {
  color: #fff;
}
.pln, .typ {
  color: #ff0;
}
.str, .lit {
  color: #0ff;
}
